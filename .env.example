# .env.example — copy to .env and fill in secrets

# LLM Provider — "ollama" | "openai" | "cerebras"
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
# Optional: larger model for planner; if unset, uses OLLAMA_MODEL (e.g. llama3.2)
# OLLAMA_PLANNER_MODEL=llama3.2
# Smaller model for classifier/evaluator/validator/response (default: same as OLLAMA_MODEL)
OLLAMA_SMALL_MODEL=llama3.2

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Cerebras
CEREBRAS_API_KEY=...
CEREBRAS_MODEL=llama3.1-8b

# RAGAS evaluation judge (optional, used only by evaluation/ragas_eval.py)
# If set, this controls which provider/model RAGAS uses as its judge and
# is independent from LLM_PROVIDER above. When unset, RAGAS falls back to
# LLM_PROVIDER (and, for the default "ollama", uses the same local Ollama
# host that agents use).
# Supported providers: "ollama" | "openai" | "cerebras"
RAGAS_LLM_PROVIDER=
# Optional judge-specific models/credentials; if omitted, the app-wide
# vars above are used.
RAGAS_OPENAI_MODEL=
RAGAS_OPENAI_BASE_URL=
RAGAS_CEREBRAS_API_KEY=
RAGAS_CEREBRAS_MODEL=
RAGAS_CEREBRAS_BASE_URL=
RAGAS_OLLAMA_MODEL=
RAGAS_OLLAMA_BASE_URL=
RAGAS_OLLAMA_API_KEY=

# Embeddings — "ollama" | "openai"
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL_OLLAMA=nomic-embed-text
EMBEDDING_MODEL_OPENAI=text-embedding-3-small

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecom_support
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# Elasticsearch (vector + content retrieval)
ES_HOST=elasticsearch
ES_PORT=9200
# Index name where documents/chunks+embeddings are stored
ES_INDEX_NAME=ecom-support-documents
# How many candidates to retrieve from ES (before reranking)
ES_RETRIEVAL_TOP_K=40

# Reranking (cross-encoder)
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# How many to return after reranking
RERANK_TOP_K=5

# ModernBERT query classification (served by BentoML container)
CLASSIFIER_BENTOML_URL=http://modernbert:3000/classify
CLASSIFIER_BENTOML_TIMEOUT_SECONDS=5
# Confidence threshold applied by BentoML classifier service
CLASSIFIER_THRESHOLD=0.7

# Server-side chat defaults (used when client omits fields)
DEFAULT_DATASET=wixqa
DEFAULT_COMPANY=default

# Planner gate for issue flow
AGENT_PLANNING_ENABLED=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CACHE_TTL=300

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ecom-support-rag

# HuggingFace — Primary Dataset (WixQA KB corpus)
HF_DATASET_PRIMARY=Wix/WixQA

# Embedding dimension — must match VECTOR(n) in schema
# 768 for nomic-embed-text (Ollama), 1536 for OpenAI text-embedding-3-small
EMBEDDING_DIM=768

# App
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8501
# Backend debug: set to true to print minimal agent/chat flow logs (stage names, tool name+params). Default: false.
DEBUG=false

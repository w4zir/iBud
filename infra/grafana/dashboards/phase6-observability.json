{
  "uid": "phase6-observability",
  "title": "Phase 6 - Agentic RAG Observability",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "graph",
      "title": "Chat Requests Rate",
      "datasource": null,
      "targets": [
        {
          "expr": "sum(rate(chat_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Chat Latency (p95)",
      "datasource": null,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(chat_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Retrieval Latency (p95)",
      "datasource": null,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(retrieval_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Redis Cache Hits",
      "datasource": null,
      "targets": [
        {
          "expr": "rate(redis_cache_hits_total[5m])",
          "legendFormat": "cache_hits",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Tool Calls by Name",
      "datasource": null,
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total[5m])) by (tool_name)",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Escalations",
      "datasource": null,
      "targets": [
        {
          "expr": "rate(escalations_total[5m])",
          "legendFormat": "escalations",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "LLM Tokens by Provider",
      "datasource": null,
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total[5m])) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}

